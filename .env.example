# HRFlow Environment Configuration
# Copy this file to .env and replace placeholder values for your environment.

# ============================================
# n8n Integration
# ============================================

# API key generated in your n8n instance
N8N_API_KEY=replace-with-your-n8n-api-key

# Credential identifiers created in your n8n instance
N8N_POSTGRES_CREDENTIAL_ID=replace-with-your-postgres-credential-id
N8N_POSTGRES_CREDENTIAL_NAME=Postgres account
N8N_SMTP_CREDENTIAL_ID=replace-with-your-smtp-credential-id
N8N_SMTP_CREDENTIAL_NAME=SMTP account

# ============================================
# Security
# ============================================

# Use a long random secret in every non-demo environment
JWT_SECRET=replace-with-a-long-random-secret

# ============================================
# Optional Configuration
# ============================================

DEFAULT_EMAIL_SENDER=noreply@example.com
DEFAULT_EMAIL_RECIPIENT=ops@example.com
