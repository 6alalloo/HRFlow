digraph BankFlowUseCases {
  graph [
    rankdir=LR,
    splines=ortho,
    nodesep=0.5,
    ranksep=1.4,
    pad=0.35,
    bgcolor="white",
    fontname="Arial",
    fontsize=18,
    label="BankFlow - Use Case Diagram",
    labelloc="t",
    labeljust="c"
  ];

  node [fontname="Arial", fontsize=11];
  edge [fontname="Arial", fontsize=10, color="#374151"];

  left_anchor [shape=point, width=0, label=""];
  right_anchor [shape=point, width=0, label=""];

  subgraph cluster_left_actors {
    style="invis";
    margin=8;

    sup [shape=box, style="rounded", color="#2B6CB0", penwidth=1.5, label="Supervisor"];
    op  [shape=box, style="rounded", color="#2B6CB0", penwidth=1.5, label="Operator"];
    appr [shape=box, style="rounded", color="#2B6CB0", penwidth=1.5, label="Approver"];

    sup -> op [style=invis, weight=10];
    op -> appr [style=invis, weight=10];
  }

  subgraph cluster_system {
    label="BankFlow System";
    style="rounded";
    color="#718096";
    penwidth=2;
    margin=20;

    subgraph cluster_operational {
      label="Operational";
      style="rounded,filled";
      fillcolor="#FAFAFA";
      color="#A0AEC0";
      penwidth=2;
      margin=20;

      node [
        shape=ellipse,
        style="filled",
        fillcolor="#EBF8FF",
        color="#2B6CB0",
        penwidth=1.7,
        margin="0.18,0.10"
      ];

      uc10 [label="Monitor Supervisor\nDashboard"];
      uc11 [label="Monitor SLA and\nOverdue Work"];
      uc12 [label="View Escalated\nCases"];
      uc02 [label="Browse and\nFilter Cases"];
      uc01 [label="Submit Manual\nCase Intake"];
      uc03 [label="View Case Detail\nand Timeline"];
      uc04 [label="Claim and\nComplete Task"];
      uc05 [label="Upload\nDocument"];
      uc07 [label="Review Approval\nRequest"];
      uc08 [label="Approve\nDecision"];
      uc09 [label="Reject\nDecision"];

      uc10 -> uc11 [style=invis, weight=8];
      uc11 -> uc12 [style=invis, weight=8];
      uc12 -> uc02 [style=invis, weight=8];
      uc02 -> uc01 [style=invis, weight=8];
      uc01 -> uc03 [style=invis, weight=8];
      uc03 -> uc04 [style=invis, weight=8];
      uc04 -> uc05 [style=invis, weight=8];
      uc05 -> uc07 [style=invis, weight=8];
      uc07 -> uc08 [style=invis, weight=8];
      uc08 -> uc09 [style=invis, weight=8];
    }

    subgraph cluster_platform {
      label="Platform";
      style="rounded,filled";
      fillcolor="#FAFAFA";
      color="#A0AEC0";
      penwidth=2;
      margin=20;

      node [
        shape=ellipse,
        style="filled",
        fillcolor="#EBF8FF",
        color="#2B6CB0",
        penwidth=1.7,
        margin="0.18,0.10"
      ];

      uc21 [label="Run KYC\nRefresh Cycle"];
      uc22 [label="Run Dormant\nAccount Scan"];
      uc23 [label="Generate Regulatory\nReport"];
      uc19 [label="View Audit Logs"];
      spacer_a [shape=plaintext, label=""];
      uc13 [label="Create and\nEdit Flow"];
      uc14 [label="Publish Flow\nVersion"];
      uc15 [label="Manage Flow\nSchedules"];
      uc16 [label="Apply Flow\nTemplate"];
      uc17 [label="Manage Users\nand Roles"];
      uc18 [label="Manage Teams\nand Queues"];
      uc20 [label="Configure Platform\nSettings"];

      uc21 -> uc22 [style=invis, weight=8];
      uc22 -> uc23 [style=invis, weight=8];
      uc23 -> uc19 [style=invis, weight=8];
      uc19 -> spacer_a [style=invis, weight=6];
      spacer_a -> uc13 [style=invis, weight=8];
      uc13 -> uc14 [style=invis, weight=8];
      uc14 -> uc15 [style=invis, weight=8];
      uc15 -> uc16 [style=invis, weight=8];
      uc16 -> uc17 [style=invis, weight=8];
      uc17 -> uc18 [style=invis, weight=8];
      uc18 -> uc20 [style=invis, weight=8];
    }
  }

  subgraph cluster_right_actors {
    style="invis";
    margin=8;

    sched [shape=box, style="rounded", color="#2B6CB0", penwidth=1.5, label="Intake Scheduler\n(System)"];
    aud [shape=box, style="rounded", color="#2B6CB0", penwidth=1.5, label="Auditor"];
    des [shape=box, style="rounded", color="#2B6CB0", penwidth=1.5, label="Designer"];
    adm [shape=box, style="rounded", color="#2B6CB0", penwidth=1.5, label="Admin"];

    sched -> aud [style=invis, weight=10];
    aud -> des [style=invis, weight=10];
    des -> adm [style=invis, weight=10];
  }

  { rank=same; left_anchor; sup; uc10; uc21; sched; right_anchor; }
  { rank=same; op; uc01; uc13; aud; }
  { rank=same; appr; uc07; uc17; des; }
  { rank=same; uc09; uc20; adm; }

  left_anchor -> sup [style=invis, weight=20];
  right_anchor -> sched [style=invis, weight=20];

  edge [style=solid, arrowhead=normal, penwidth=1.5, color="#374151"];

  sup -> uc10;
  sup -> uc11;
  sup -> uc12;

  op -> uc02;
  op -> uc01;
  op -> uc03;
  op -> uc04;
  op -> uc05;

  appr -> uc07;
  appr -> uc08;
  appr -> uc09;

  uc21 -> sched;
  uc22 -> sched;
  uc23 -> sched;

  uc19 -> aud;
  uc03 -> aud;

  uc13 -> des;
  uc14 -> des;
  uc15 -> des;
  uc16 -> des;

  uc17 -> adm;
  uc18 -> adm;
  uc20 -> adm;

  edge [
    style=dashed,
    arrowhead=open,
    arrowsize=0.8,
    penwidth=1.2,
    color="#6B7280",
    fontcolor="#6B7280",
    fontsize=9
  ];

  uc14 -> uc13 [label="<<include>>", labeldistance=1.4, minlen=1];
  uc08 -> uc07 [label="<<include>>", labeldistance=1.4, minlen=1];
  uc09 -> uc07 [label="<<include>>", labeldistance=1.4, minlen=1];
  uc04 -> uc03 [label="<<extend>>", labeldistance=1.4, minlen=1];
  uc05 -> uc03 [label="<<extend>>", labeldistance=1.6, minlen=1];
}
